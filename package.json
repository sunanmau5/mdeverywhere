{
  "name": "@sunanmau5/mdeverywhere",
  "version": "0.1.0",
  "description": "ESM-first Markdown converters for chat apps and a browser demo.",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./browser-app": "./src/browser-app.js",
    "./markdown-parser": "./src/markdown-parser.js",
    "./converters/*": "./src/converters/*.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "serve -l 8000 .",
    "dev": "serve -l 8000 .",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "corepack pnpm lint && corepack pnpm test"
  },
  "keywords": [
    "markdown",
    "converter",
    "esm",
    "whatsapp",
    "slack",
    "discord",
    "telegram",
    "html"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunanmau5/mdeverywhere.git"
  },
  "homepage": "https://sunanmau5.github.io/mdeverywhere/",
  "bugs": {
    "url": "https://github.com/sunanmau5/mdeverywhere/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "serve": "^14.2.6",
    "vitest": "^4.1.2"
  }
}
